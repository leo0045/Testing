# Pasta monitorada (absoluta ou relativa ao script)
MONITOR_DIR=./dados

# Evolution API
EVOLUTION_API_URL=https://sua-evolution-api.com
EVOLUTION_API_KEY=sua-chave-api
EVOLUTION_INSTANCE=nome-da-instancia

# Número WhatsApp destino (código do país + DDD + número, sem + ou espaços)
WHATSAPP_NUMBER=5511999999999

# Opcional: URL completa do webhook (se definida, tem prioridade sobre a montagem automática)
# EVOLUTION_WEBHOOK_URL=https://sua-evolution-api.com/message/sendText/nome-da-instancia

# Modo teste: loga a mensagem sem chamar a API (true/false)
# DRY_RUN=true
